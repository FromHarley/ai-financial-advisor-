# Copy this file to `.env` and fill in the values.
# The `.env` file is gitignored and must stay that way.
#
# Do NOT paste these keys in Discord, Slack, email, or anywhere else.
# If you need a key, DM Alex directly. If you ever leak a key, tell Alex
# immediately so we can rotate it — hiding a leak is the only thing
# that causes real problems.

# Anthropic API key — used by Layer 2 (Claude) for the explanation layer.
# Required if you're working on Layer 2 or running the full end-to-end app.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — used by the Voice layer for Whisper transcription.
# Required ONLY if you're working on the voice feature or running the
# full app with voice enabled. Layers 1/3/4 do not need this.
OPENAI_API_KEY=sk-...

# Model selections — change only if the team agrees at a meeting.
CLAUDE_MODEL=claude-opus-4-7
WHISPER_MODEL=whisper-1
